# ── MODE: operation ────────────────────────────────────────────────────────────
# Default: cardiovascular risk prediction (interview task).
# Single POST endpoint, no database. Model is pre-trained and available.
#
# To use for a different domain, replace everything below the mode line.
# For CRUD apps see the resource mode example at the bottom of this file.

mode: operation

project:
  name: calibre
  package: calibre
  description: "Cardiovascular risk prediction API"

domain:
  input_model: RiskInput
  output_model: RiskOutput
  endpoint_path: predict              # → POST /api/v1/predict
  handler_name: predict_risk
  business_logic_fn: predict

# Patient data passed to the ML model.
# systolic_bp must be declared before diastolic_bp — Pydantic v2 cross-field
# validators only see fields declared earlier in the model (info.data).
input_fields:
  - { name: age,              type: int,   constraints: "ge=18, le=120" }
  - { name: systolic_bp,      type: int,   constraints: "ge=70, le=250" }
  - { name: diastolic_bp,     type: int,   constraints: "ge=40, le=150" }
  - { name: total_cholesterol, type: float, constraints: "ge=100.0, le=600.0" }
  - { name: hdl_cholesterol,  type: float, constraints: "ge=10.0, le=150.0" }
  - { name: diabetes,         type: bool }
  - { name: smoker,           type: bool }
  - { name: on_bp_treatment,  type: bool,  default: false }

# Estimated probability of a cardiovascular event at each time horizon (0–100).
# risk_category uses Literal so openapi-typescript generates a TS union type,
# not bare string — "Low" | "Moderate" | "High" | "Very High" in the frontend.
output_fields:
  - { name: year1,          type: float }
  - { name: year5,          type: float }
  - { name: year10,         type: float }
  - { name: year15,         type: float }
  - { name: year20,         type: float }
  - { name: risk_category,  type: 'Literal["Low", "Moderate", "High", "Very High"]' }
  - { name: model_version,  type: str }

frontend:
  form_component: RiskForm
  result_component: RiskChart



# ── MODE: resource ─────────────────────────────────────────────────────────────
# Full CRUD REST API with SQLite/SQLAlchemy (swap to Postgres via one env var).
# Use for: data management apps, admin dashboards, most real-world backends.
#
# mode: resource
#
# project:
#   name: myapp
#   package: myapp
#   description: "My full-stack app"
#
# resource:
#   name: Item                    # PascalCase singular — scaffold derives items, item_id etc.
#   # plural: items               # optional override (default: name.lower() + 's')
#   fields:
#     - { name: title,       type: str }
#     - { name: amount,      type: float, constraints: "ge=0" }
#     - { name: is_active,   type: bool,  default: true }
#
# database:
#   dev: sqlite                   # sqlite (default, zero-infra) | postgres
#   # docker: true                # uncomment → generates docker-compose.yml for postgres
#
# frontend:
#   list_component: ItemTable
#   form_component: ItemForm
#   detail_component: ItemDetail
