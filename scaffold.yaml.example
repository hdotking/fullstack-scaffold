# ── MODE: operation ────────────────────────────────────────────────────────────
# Single POST endpoint, no database.
# Use for: ML inference, scoring APIs, calculators, interview tasks.
#
# mode: operation
#
# project:
#   name: creditcheck
#   package: creditcheck
#   description: "Credit scoring API for loan applications"
#
# domain:
#   input_model: LoanApplication
#   output_model: CreditDecision
#   endpoint_path: assess         # → POST /api/v1/assess
#   handler_name: assess_application
#   business_logic_fn: assess
#
# input_fields:
#   - { name: applicant_age,  type: int,   constraints: "ge=18, le=100" }
#   - { name: annual_income,  type: float, constraints: "ge=0" }
#   - { name: has_bankruptcy, type: bool }
#   - { name: is_existing_customer, type: bool, default: false }
#
# output_fields:
#   - { name: approved,      type: bool }
#   - { name: risk_tier,     type: 'Literal["A", "B", "C", "D"]' }
#   - { name: model_version, type: str }
#
# frontend:
#   form_component: LoanForm
#   result_component: DecisionSummary


# ── MODE: resource ─────────────────────────────────────────────────────────────
# Full CRUD REST API with SQLite/SQLAlchemy (swap to Postgres via one env var).
# Use for: data management apps, admin dashboards, most real-world backends.

mode: resource

project:
  name: myapp
  package: myapp
  description: "My full-stack app"

resource:
  name: Item                    # PascalCase singular — scaffold derives items, item_id etc.
  # plural: items               # optional override (default: name.lower() + 's')
  fields:
    - { name: title,       type: str }
    - { name: amount,      type: float, constraints: "ge=0" }
    - { name: is_active,   type: bool,  default: true }

database:
  dev: sqlite                   # sqlite (default, zero-infra) | postgres
  # docker: true                # uncomment → generates docker-compose.yml for postgres

frontend:
  list_component: ItemTable
  form_component: ItemForm
  detail_component: ItemDetail
