import { render, screen } from '@testing-library/react'
import { describe, it, expect, vi } from 'vitest'
import { <<frontend.form_component>> } from '../<<frontend.form_component>>'

describe('<<frontend.form_component>>', () => {
  it('renders submit button', () => {
    render(<<lt>><<frontend.form_component>> onSubmit={vi.fn()} loading={false} />)
    expect(screen.getByRole('button', { name: /submit/i })).toBeInTheDocument()
  })

  it('disables button when loading', () => {
    render(<<lt>><<frontend.form_component>> onSubmit={vi.fn()} loading={true} />)
    expect(screen.getByRole('button')).toBeDisabled()
  })
})
