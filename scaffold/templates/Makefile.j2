.PHONY: backend frontend types test lint typecheck<% if mode == "resource" %> db-init<% endif %>

backend:
	uv run serve

frontend:
	npm --prefix frontend run dev

types:
	uv run python backend/scripts/generate_openapi.py
	npm --prefix frontend run generate:types

test:
	uv run pytest -v
	npm --prefix frontend run test

lint:
	uv run ruff check backend/src backend/tests
	uv run ruff format backend/src backend/tests
	cd frontend && npx eslint src --max-warnings 0

typecheck:
	uv run mypy backend/src
	cd frontend && npx tsc --noEmit
<% if mode == "resource" %>
db-init:
	uv run python -c "from <<project.package>>.database import Base, engine; Base.metadata.create_all(engine); print('tables created')"
<% endif %>
